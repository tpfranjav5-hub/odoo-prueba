<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_panaderia_list" model="ir.ui.view">
            <field name="name">product.product.panaderia.list</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <!-- Usamos 'list' para Odoo 19 -->
                <list string="Ajuste Rápido de Stock" editable="top" create="0" delete="0">
                    <header>
                        <!-- Este botón aparecerá arriba en la barra de acciones -->
                        <button name="action_validate_panaderia_bulk" 
                                string="ACTUALIZAR STOCK" 
                                type="object" 
                                class="btn-primary"/>
                    </header>
                    <field name="display_name" readonly="1" string="Producto"/>
                    <field name="new_stock_quantity" string="Cantidad Contada"/>
                </list>
            </field>
        </record>

        <record id="action_stock_panaderia" model="ir.actions.act_window">
            <field name="name">Gestión de Stock Panadería</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_product_panaderia_list"/>
            <!-- Solo mostramos productos que se pueden almacenar -->
            <field name="domain">[('type', '=', 'consu')]</field> 
        </record>

        <menuitem id="menu_panaderia_root" name="Inventario Pan" sequence="1"/>
        <menuitem id="menu_panaderia_stock" name="Ajuste de Stock" parent="menu_panaderia_root" action="action_stock_panaderia" sequence="1"/>
    </data>
</odoo>